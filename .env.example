NODE_ENV=development

# Public URLs
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
WEB_ALLOWED_ORIGINS=http://localhost:3000,https://courtwatchaau.com,https://www.courtwatchaau.com,https://app.courtwatchaau.com

# Database
DATABASE_URL=postgresql://courtwatch:courtwatch@localhost:5432/courtwatch_reno?schema=public

# Exposure/Jam On It source
EXPOSURE_API_KEY=
EXPOSURE_SECRET_KEY=
EXPOSURE_EVENT_ID=255539
EXPOSURE_EVENT_SLUG=2026-reno-memorial-day-tournament
DEFAULT_EXPOSURE_EVENT_ID=255539
EXPOSURE_PUBLIC_BASE_URL=https://basketball.exposureevents.com
EXPOSURE_PUBLIC_FETCH_ALL_GAMES=false
EXPOSURE_PUBLIC_REQUEST_DELAY_MS=125
EXPOSURE_PUBLIC_TIMEOUT_MS=12000
EXPOSURE_API_TIMEOUT_MS=12000
TOURNAMENT_DISCOVERY_ENABLED=true
TOURNAMENT_DISCOVERY_INTERVAL_HOURS=6
TOURNAMENT_DISCOVERY_WINDOW_DAYS=183
WORKER_SYNC_BATCH_SIZE=12
TOURNAMENT_DROPDOWN_CACHE_HOURS=720
TOURNAMENT_DISCOVERY_REQUEST_DELAY_MS=125
TOURNAMENT_DISCOVERY_RESPECT_ROBOTS=true
ENABLE_MOCK_ARSENAL=false
ENABLE_MOCK_DATA=false
WORKER_API_TIMEOUT_MS=300000

# Push notifications
EXPO_ACCESS_TOKEN=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
PUSH_CONTACT_EMAIL=mailto:admin@example.com

# App security
JWT_SECRET=replace-with-a-random-string
ADMIN_SECRET=replace-with-a-random-admin-secret

# Optional account password reset email
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=Court Watch AAU <no-reply@courtwatchaau.com>
PASSWORD_RESET_EXPOSE_TOKEN=false

# Render automation; do not commit real values.
RENDER_API_KEY=
