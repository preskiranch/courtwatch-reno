generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now()) @map("created_at")
  clientId             String?   @unique @map("client_id")
  email                String?   @unique
  passwordHash         String?   @map("password_hash")
  sessionVersion       Int       @default(0) @map("session_version")
  emailVerifiedAt      DateTime? @map("email_verified_at")
  displayName          String?   @map("display_name")
  pushSubscriptionJson Json?     @map("push_subscription_json")
  expoPushToken        String?   @map("expo_push_token")
  timezone             String    @default("America/Los_Angeles")

  watchlists              ProgramWatchlist[]
  notificationPreferences NotificationPreference[]
  notificationLogs        NotificationLog[]
  passwordResetTokens     PasswordResetToken[]
  favoriteTeamWatches     FavoriteTeamWatch[]
  accountSessions         AccountSession[]

  @@map("users")
}

model AccountSession {
  id         String    @id
  userId     String    @map("user_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt], map: "account_sessions_user_active_idx")
  @@index([expiresAt], map: "account_sessions_expires_at_idx")
  @@map("account_sessions")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Event {
  id                  String    @id @default(cuid())
  exposureEventId     Int       @unique @map("exposure_event_id")
  externalProvider    String    @default("exposure_events") @map("external_provider")
  externalId          String    @map("external_id")
  sourceUrl           String?   @map("source_url")
  name                String
  organizer           String
  sport               String    @default("basketball")
  sanctioningTags     String[]  @default([]) @map("sanctioning_tags")
  gender              String?
  ageOrGradeDivisions String[]  @default([]) @map("age_or_grade_divisions")
  venueName           String?   @map("venue_name")
  city                String?
  state               String?
  region              String?
  startDate           DateTime  @map("start_date") @db.Date
  endDate             DateTime  @map("end_date") @db.Date
  location            String
  officialUrl         String    @map("official_url")
  registeredTeamCount Int       @default(0) @map("registered_team_count")
  hasPublicTeamList   Boolean   @default(false) @map("has_public_team_list")
  lastCheckedAt       DateTime? @map("last_checked_at")
  lastSyncedAt        DateTime? @map("last_synced_at")
  lastTeamChangeAt    DateTime? @map("last_team_change_at")
  status              String    @default("upcoming")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  divisions                       Division[]
  teams                           Team[]
  players                         Player[]
  games                           Game[]
  divisionResults                 DivisionResult[]
  syncRuns                        SyncRun[]
  favoriteTeamRegistrationMatches FavoriteTeamRegistrationMatch[]

  @@unique([externalProvider, externalId])
  @@index([status, startDate])
  @@index([region, status, startDate], map: "events_region_status_start_date_idx")
  @@index([startDate, endDate], map: "events_start_end_date_idx")
  @@index([lastCheckedAt], map: "events_last_checked_at_idx")
  @@map("events")
}

model ProgramWatchlist {
  id                    String   @id @default(cuid())
  userId                String?  @map("user_id")
  programName           String   @map("program_name")
  normalizedProgramName String   @map("normalized_program_name")
  active                Boolean  @default(true)
  createdAt             DateTime @default(now()) @map("created_at")

  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  aliases      ProgramAlias[]
  matches      ProgramTeamMatch[]
  changeEvents GameChangeEvent[]

  @@unique([userId, normalizedProgramName])
  @@map("program_watchlist")
}

model ProgramAlias {
  id                 String   @id @default(cuid())
  programWatchlistId String   @map("program_watchlist_id")
  alias              String
  normalizedAlias    String   @map("normalized_alias")
  createdAt          DateTime @default(now()) @map("created_at")

  programWatchlist ProgramWatchlist @relation(fields: [programWatchlistId], references: [id], onDelete: Cascade)

  @@unique([programWatchlistId, normalizedAlias])
  @@map("program_aliases")
}

model Division {
  id                 String  @id @default(cuid())
  eventId            String  @map("event_id")
  exposureDivisionId String? @map("exposure_division_id")
  name               String
  gender             String?
  gradeLevel         String? @map("grade_level")
  level              String?
  rawJson            Json?   @map("raw_json")

  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teams   Team[]
  games   Game[]
  results DivisionResult[]

  @@unique([eventId, exposureDivisionId])
  @@index([eventId], map: "divisions_event_id_idx")
  @@map("divisions")
}

model Team {
  id                 String   @id @default(cuid())
  eventId            String   @map("event_id")
  divisionId         String?  @map("division_id")
  exposureTeamId     String?  @map("exposure_team_id")
  name               String
  normalizedName     String   @map("normalized_name")
  clubName           String?  @map("club_name")
  normalizedClubName String?  @map("normalized_club_name")
  coachName          String?  @map("coach_name")
  city               String?
  state              String?
  sourceUrl          String?  @map("source_url")
  rawJson            Json?    @map("raw_json")
  lastSeenAt         DateTime @map("last_seen_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  event                           Event                           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  division                        Division?                       @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  matches                         ProgramTeamMatch[]
  players                         Player[]
  divisionResults                 DivisionResult[]
  homeGames                       Game[]                          @relation("HomeTeam")
  awayGames                       Game[]                          @relation("AwayTeam")
  changeEvents                    GameChangeEvent[]
  favoriteTeamRegistrationMatches FavoriteTeamRegistrationMatch[]

  @@unique([eventId, exposureTeamId])
  @@index([normalizedName])
  @@index([eventId, normalizedName], map: "teams_event_id_normalized_name_idx")
  @@index([eventId, divisionId], map: "teams_event_id_division_id_idx")
  @@map("teams")
}

model Player {
  id               String   @id @default(cuid())
  eventId          String   @map("event_id")
  teamId           String?  @map("team_id")
  exposurePlayerId String?  @map("exposure_player_id")
  firstName        String?  @map("first_name")
  lastName         String?  @map("last_name")
  fullName         String   @map("full_name")
  normalizedName   String   @map("normalized_name")
  jerseyNumber     String?  @map("jersey_number")
  position         String?
  grade            String?
  rawJson          Json?    @map("raw_json")
  lastSeenAt       DateTime @map("last_seen_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team  Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([eventId, exposurePlayerId])
  @@index([normalizedName])
  @@index([teamId])
  @@map("players")
}

model ProgramTeamMatch {
  id                 String   @id @default(cuid())
  programWatchlistId String   @map("program_watchlist_id")
  teamId             String   @map("team_id")
  matchType          String   @map("match_type")
  matchConfidence    Decimal  @map("match_confidence") @db.Decimal(5, 2)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")

  programWatchlist ProgramWatchlist @relation(fields: [programWatchlistId], references: [id], onDelete: Cascade)
  team             Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([programWatchlistId, teamId])
  @@index([teamId], map: "program_team_matches_team_id_idx")
  @@index([programWatchlistId, active], map: "program_team_matches_program_active_idx")
  @@map("program_team_matches")
}

model Game {
  id                   String   @id @default(cuid())
  eventId              String   @map("event_id")
  divisionId           String?  @map("division_id")
  exposureGameId       String?  @map("exposure_game_id")
  gameNumber           String?  @map("game_number")
  gameType             String?  @map("game_type")
  scheduledDate        DateTime @map("scheduled_date") @db.Date
  scheduledTime        String   @map("scheduled_time")
  startsAt             DateTime @map("starts_at") @db.Timestamptz(6)
  timezone             String
  venueName            String?  @map("venue_name")
  courtName            String?  @map("court_name")
  homeTeamId           String?  @map("home_team_id")
  awayTeamId           String?  @map("away_team_id")
  homeTeamNameSnapshot String?  @map("home_team_name_snapshot")
  awayTeamNameSnapshot String?  @map("away_team_name_snapshot")
  homeScore            Int?     @map("home_score")
  awayScore            Int?     @map("away_score")
  status               String
  officialUrl          String?  @map("official_url")
  streamingUrl         String?  @map("streaming_url")
  updatedAt            DateTime @updatedAt @map("updated_at")
  sourceHash           String   @map("source_hash")
  rawJson              Json?    @map("raw_json")

  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  division     Division?         @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  homeTeam     Team?             @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam     Team?             @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  changeEvents GameChangeEvent[]

  @@unique([eventId, exposureGameId])
  @@index([startsAt])
  @@index([eventId, startsAt], map: "games_event_id_starts_at_idx")
  @@index([eventId, status, startsAt], map: "games_event_id_status_starts_at_idx")
  @@index([homeTeamId, startsAt], map: "games_home_team_id_starts_at_idx")
  @@index([awayTeamId, startsAt], map: "games_away_team_id_starts_at_idx")
  @@index([divisionId, startsAt], map: "games_division_id_starts_at_idx")
  @@map("games")
}

model GameChangeEvent {
  id                         String   @id @default(cuid())
  gameId                     String?  @map("game_id")
  affectedTeamId             String?  @map("affected_team_id")
  affectedProgramWatchlistId String?  @map("affected_program_watchlist_id")
  favoriteTeamWatchId        String?  @map("favorite_team_watch_id")
  eventType                  String   @map("event_type")
  previousValue              Json?    @map("previous_value")
  newValue                   Json?    @map("new_value")
  createdAt                  DateTime @default(now()) @map("created_at")
  notificationSent           Boolean  @default(false) @map("notification_sent")
  dedupeKey                  String   @unique @map("dedupe_key")

  game                     Game?              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  affectedTeam             Team?              @relation(fields: [affectedTeamId], references: [id], onDelete: SetNull)
  affectedProgramWatchlist ProgramWatchlist?  @relation(fields: [affectedProgramWatchlistId], references: [id], onDelete: SetNull)
  favoriteTeamWatch        FavoriteTeamWatch? @relation(fields: [favoriteTeamWatchId], references: [id], onDelete: SetNull)
  notificationLogs         NotificationLog[]

  @@index([createdAt])
  @@index([gameId, createdAt], map: "game_change_events_game_id_created_at_idx")
  @@index([affectedTeamId, createdAt], map: "game_change_events_team_id_created_at_idx")
  @@index([affectedProgramWatchlistId, createdAt], map: "game_change_events_watchlist_id_created_at_idx")
  @@index([favoriteTeamWatchId, createdAt], map: "game_change_events_favorite_watch_id_created_at_idx")
  @@index([notificationSent, createdAt], map: "game_change_events_notification_created_at_idx")
  @@map("game_change_events")
}

model DivisionResult {
  id               String   @id @default(cuid())
  eventId          String   @map("event_id")
  divisionId       String   @map("division_id")
  teamId           String?  @map("team_id")
  placement        Int
  medalLabel       String   @map("medal_label")
  bracketLabel     String?  @map("bracket_label")
  teamNameSnapshot String   @map("team_name_snapshot")
  source           String
  sourceUrl        String?  @map("source_url")
  isOfficial       Boolean  @default(false) @map("is_official")
  sourceHash       String   @map("source_hash")
  rawJson          Json?    @map("raw_json")
  lastSeenAt       DateTime @default(now()) @map("last_seen_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  division Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  team     Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([eventId, divisionId, placement])
  @@index([divisionId])
  @@index([teamId])
  @@index([eventId, divisionId], map: "division_results_event_division_idx")
  @@index([eventId, teamId], map: "division_results_event_team_idx")
  @@map("division_results")
}

model NotificationPreference {
  id                       String  @id @default(cuid())
  userId                   String  @map("user_id")
  newTeamDiscovered        Boolean @default(true) @map("new_team_discovered")
  newGameAdded             Boolean @default(true) @map("new_game_added")
  gameTimeChanged          Boolean @default(true) @map("game_time_changed")
  courtChanged             Boolean @default(true) @map("court_changed")
  venueChanged             Boolean @default(true) @map("venue_changed")
  opponentAssigned         Boolean @default(true) @map("opponent_assigned")
  scorePosted              Boolean @default(true) @map("score_posted")
  finalScore               Boolean @default(true) @map("final_score")
  bracketUpdate            Boolean @default(true) @map("bracket_update")
  gameStartReminderMinutes Int[]   @default([60, 30, 15]) @map("game_start_reminder_minutes")
  dailyDigest              Boolean @default(true) @map("daily_digest")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("notification_preferences")
}

model NotificationLog {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  gameChangeEventId String?   @map("game_change_event_id")
  title             String
  body              String
  channel           String
  clickUrl          String?   @map("click_url")
  sentAt            DateTime? @map("sent_at")
  status            String
  errorMessage      String?   @map("error_message")
  dedupeKey         String    @map("dedupe_key")
  attemptCount      Int       @default(0) @map("attempt_count")
  nextAttemptAt     DateTime? @map("next_attempt_at")
  lastAttemptAt     DateTime? @map("last_attempt_at")
  deliveredAt       DateTime? @map("delivered_at")
  deadLetteredAt    DateTime? @map("dead_lettered_at")
  leaseExpiresAt    DateTime? @map("lease_expires_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameChangeEvent GameChangeEvent? @relation(fields: [gameChangeEventId], references: [id], onDelete: SetNull)

  @@unique([userId, dedupeKey, channel])
  @@index([userId, sentAt], map: "notification_log_user_sent_at_idx")
  @@index([status, sentAt], map: "notification_log_status_sent_at_idx")
  @@index([status, nextAttemptAt], map: "notification_log_status_next_attempt_idx")
  @@index([status, leaseExpiresAt], map: "notification_log_status_lease_idx")
  @@index([gameChangeEventId, status], map: "notification_log_change_status_idx")
  @@map("notification_log")
}

model FavoriteTeamWatch {
  id             String    @id @default(cuid())
  userId         String?   @map("user_id")
  ownerHash      String    @map("owner_hash")
  displayName    String    @map("display_name")
  normalizedName String    @map("normalized_name")
  source         String    @default("custom")
  sourceTeamId   String?   @map("source_team_id")
  sourceTeamName String?   @map("source_team_name")
  eventName      String?   @map("event_name")
  divisionName   String?   @map("division_name")
  gender         String?
  gradeLevel     String?   @map("grade_level")
  level          String?
  autoFollow     Boolean   @default(false) @map("auto_follow")
  lastMatchedAt  DateTime? @map("last_matched_at")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user                User?                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  registrationMatches FavoriteTeamRegistrationMatch[]
  changeEvents        GameChangeEvent[]

  @@unique([ownerHash, normalizedName])
  @@index([ownerHash])
  @@index([normalizedName])
  @@index([sourceTeamId])
  @@index([ownerHash, active], map: "favorite_team_watches_owner_active_idx")
  @@map("favorite_team_watches")
}

model FavoriteTeamRegistrationMatch {
  id                  String    @id @default(cuid())
  favoriteTeamWatchId String    @map("favorite_team_watch_id")
  teamId              String    @map("team_id")
  eventId             String    @map("event_id")
  detectedAt          DateTime  @default(now()) @map("detected_at")
  autoFollowAppliedAt DateTime? @map("auto_follow_applied_at")

  favoriteTeamWatch FavoriteTeamWatch @relation(fields: [favoriteTeamWatchId], references: [id], onDelete: Cascade)
  team              Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  event             Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([favoriteTeamWatchId, teamId])
  @@index([favoriteTeamWatchId, eventId], map: "favorite_team_registration_matches_watch_event_idx")
  @@index([teamId], map: "favorite_team_registration_matches_team_idx")
  @@index([eventId], map: "favorite_team_registration_matches_event_idx")
  @@map("favorite_team_registration_matches")
}

model SyncRun {
  id              String    @id @default(cuid())
  eventId         String    @map("event_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  status          String
  source          String
  teamsCount      Int       @default(0) @map("teams_count")
  gamesCount      Int       @default(0) @map("games_count")
  changesDetected Int       @default(0) @map("changes_detected")
  errorMessage    String?   @map("error_message")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([startedAt])
  @@index([eventId, status, completedAt], map: "sync_runs_event_status_completed_idx")
  @@index([eventId, startedAt], map: "sync_runs_event_started_idx")
  @@map("sync_runs")
}

model SyncLease {
  key        String   @id
  ownerId    String   @map("owner_id")
  acquiredAt DateTime @default(now()) @map("acquired_at")
  expiresAt  DateTime @map("expires_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([expiresAt], map: "sync_leases_expires_at_idx")
  @@map("sync_leases")
}

model PresenceSession {
  clientId   String   @id @map("client_id")
  page       String?
  lastSeenAt DateTime @map("last_seen_at")

  @@index([lastSeenAt], map: "presence_sessions_last_seen_at_idx")
  @@index([page, lastSeenAt], map: "presence_sessions_page_last_seen_at_idx")
  @@map("presence_sessions")
}
